# by gojo.exe
# IQ_HARRY_07
#
# Boot partitions
/boot           emmc    /dev/block/by-name/boot           flags=backup=1;display="Boot";flashimg=1;slotselect
/init_boot      emmc    /dev/block/by-name/init_boot      flags=backup=1;display="Init Boot";flashimg=1;slotselect
/vendor_boot    emmc    /dev/block/by-name/vendor_boot    flags=backup=1;display="Vendor Boot";flashimg=1;slotselect
/dtbo           emmc    /dev/block/by-name/dtbo           flags=backup=1;display="DTBO";flashimg=1;slotselect

# VBMeta
/vbmeta         emmc    /dev/block/by-name/vbmeta         flags=backup=1;display="VBMeta";flashimg=1;slotselect
/vbmeta_system  emmc    /dev/block/by-name/vbmeta_system  flags=backup=1;display="VBMeta System";flashimg=1;slotselect
/vbmeta_vendor  emmc    /dev/block/by-name/vbmeta_vendor  flags=backup=1;display="VBMeta Vendor";flashimg=1;slotselect

# Dynamic partitions (EROFS + EXT4 fallback)
/system         erofs   system                            flags=display="System";logical;slotselect
/system         ext4    system                            flags=display="System";logical;slotselect

/system_ext     erofs   system_ext                        flags=display="System Ext";logical;slotselect
/system_ext     ext4    system_ext                        flags=display="System Ext";logical;slotselect

/vendor         erofs   vendor                            flags=display="Vendor";logical;slotselect
/vendor         ext4    vendor                            flags=display="Vendor";logical;slotselect

/product        erofs   product                           flags=display="Product";logical;slotselect
/product        ext4    product                           flags=display="Product";logical;slotselect

/vendor_dlkm    erofs   vendor_dlkm                       flags=display="Vendor DLKM";logical;slotselect
/vendor_dlkm    ext4    vendor_dlkm                       flags=display="Vendor DLKM";logical;slotselect

/odm_dlkm       erofs   odm_dlkm                          flags=display="ODM DLKM";logical;slotselect
/odm_dlkm       ext4    odm_dlkm                          flags=display="ODM DLKM";logical;slotselect

# Data
/data           f2fs    /dev/block/by-name/userdata       flags=fileencryption=aes-256-xts:aes-256-cts:v2+inlinecrypt_optimized,keydirectory=/metadata/vold/metadata_encryption;metadata_encryption=aes-256-xts:wrappedkey_v0

/metadata       ext4    /dev/block/by-name/metadata       flags=display="Metadata";backup=1
/persist        ext4    /dev/block/by-name/persist        flags=display="Persist";backup=1

# NVRAM
/nvram          emmc    /dev/block/by-name/nvram          flags=display="NVRAM";backup=1
/nvdata         ext4    /dev/block/by-name/nvdata         flags=display="NVData";backup=1
/nvcfg          ext4    /dev/block/by-name/nvcfg          flags=display="NVCFG";backup=1

# Storage
/external_sd    vfat    /dev/block/mmcblk0p1 /dev/block/mmcblk0 flags=display="External SD";storage;wipeui;removable
/usb_otg        vfat    /dev/block/sdd1 /dev/block/sdd    flags=display="USB-OTG";storage;wipeui;removable
