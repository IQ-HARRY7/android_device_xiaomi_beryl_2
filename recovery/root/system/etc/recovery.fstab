# Logical Partitions
system                                                  /system                erofs   ro                                                                           wait,slotselect,avb=vbmeta_system,logical,first_stage_mount
system                                                  /system                ext4    ro                                                                           wait,slotselect,avb=vbmeta_system,logical,first_stage_mount
vendor                                                  /vendor                erofs   ro                                                                           wait,slotselect,avb=vbmeta_vendor,logical,first_stage_mount
vendor                                                  /vendor                ext4    ro                                                                           wait,slotselect,avb=vbmeta_vendor,logical,first_stage_mount
product                                                 /product               erofs   ro                                                                           wait,slotselect,avb,logical,first_stage_mount
product                                                 /product               ext4    ro                                                                           wait,slotselect,avb,logical,first_stage_mount
system_ext                                              /system_ext            erofs   ro                                                                           wait,slotselect,logical
mi_ext                                                  /mi_ext                erofs   ro                                                                           wait,slotselect,logical
vendor_dlkm                                             /vendor_dlkm           erofs   ro                                                                           wait,slotselect,logical
system_dlkm                                             /system_dlkm           erofs   ro                                                                           wait,slotselect,logical
odm                                                     /odm                   erofs   ro                                                                           wait,slotselect,logical,first_stage_mount
odm                                                     /odm                   ext4    ro                                                                           wait,slotselect,logical,first_stage_mount
odm_dlkm                                                /odm_dlkm              ext4    ro                                                                           wait,slotselect,logical
odm_dlkm                                                /odm_dlkm              erofs   ro                                                                           wait,slotselect,logical

/dev/block/by-name/metadata                  /metadata              ext4    noatime,nosuid,nodev,discard                                                 wait,check,formattable
/dev/block/by-name/userdata                  /data                  f2fs    noatime,nosuid,nodev,discard,noflush_merge,fsync_mode=nobarrier,reserve_root=134217,resgid=1065,checkpoint_merge,gc_merge,inlinecrypt wait,check,formattable,quota,latemount,resize,reservedsize=128m,checkpoint=fs,fileencryption=aes-256-xts:aes-256-cts:v2+inlinecrypt_optimized,keydirectory=/metadata/vold/metadata_encryption,fsverity
/dev/block/by-name/userdata                  /data                  mifs    noatime,nosuid,nodev,discard,noflush_merge,fsync_mode=nobarrier,reserve_root=134217,resgid=1065,checkpoint_merge,gc_merge,inlinecrypt wait,check,formattable,quota,latemount,resize,reservedsize=128m,checkpoint=fs,fileencryption=aes-256-xts:aes-256-cts:v2+inlinecrypt_optimized,keydirectory=/metadata/vold/metadata_encryption,fsverity
/dev/block/by-name/boot                      /boot                  emmc    defaults                                                                     first_stage_mount,nofail,slotselect
/dev/block/by-name/vendor_boot               /vendor_boot           emmc    defaults                                                                     first_stage_mount,nofail,slotselect
/dev/block/by-name/dtbo                      /dtbo                  emmc    defaults                                                                     first_stage_mount,nofail,slotselect
/dev/block/by-name/vbmeta                    /vbmeta                emmc    defaults                                                                     first_stage_mount,nofail,slotselect
/dev/block/by-name/persist                   /persist               ext4    noatime,nosuid,nodev,barrier=1                                               wait,formattable
/dev/block/by-name/misc                      /misc                  emmc    defaults                                                                     defaults
